FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY pg/faq_api/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY pg/faq_api /app/pg/faq_api

EXPOSE 8000

CMD ["uvicorn", "pg.faq_api.main:app", "--host", "0.0.0.0", "--port", "8000"]

